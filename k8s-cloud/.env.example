# Environment Variables Template for IBM Cloud Code Engine Deployment
# Copy this file to .env and fill in your actual values

# AstraDB Configuration
ASTRADB_API_ENDPOINT=https://your-database-id-region.apps.astra.datastax.com
ASTRADB_TOKEN=AstraCS:xxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# OpenAI Configuration
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# IBM Cloud Configuration (Optional - for deployment script)
CODE_ENGINE_PROJECT=pdf-astradb-project
CONTAINER_REGISTRY=us.icr.io
REGISTRY_NAMESPACE=your-namespace
IMAGE_TAG=latest

# Application Configuration (Optional)
PORT=8080
COLLECTION_NAME=langchain_docling_gui
EMBEDDING_MODEL=text-embedding-ada-002
CHAT_MODEL=gpt-3.5-turbo-16k